{
  "name": "@liustack/pagepress",
  "version": "1.0.0",
  "description": "CLI tool to render local HTML files into PDF",
  "type": "module",
  "bin": {
    "pagepress": "./dist/main.js"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build",
    "docs:list": "node scripts/docs-list.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "pdf",
    "html-to-pdf",
    "pdf-report",
    "cli",
    "playwright"
  ],
  "author": "Leon Liu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liustack/pagepress.git"
  },
  "bugs": {
    "url": "https://github.com/liustack/pagepress/issues"
  },
  "homepage": "https://github.com/liustack/pagepress#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "playwright": "^1.58.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-node": "^5.0.1",
    "vitest": "^4.0.18"
  }
}
